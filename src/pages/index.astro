---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import ProductCard from "../components/ProductCard.astro";
import { getCollection } from "astro:content";

const products = await getCollection("products");

// Grouping logic for the layout (some cards have top margin in the prototype)
---

<Layout title="BOUTIQUE | Summer Collection 2024">
	<Header />
	<main class="pt-0">
		<Hero
			title="Summer Collection 2024"
			subtitle="New Narrative"
			cta="Explore Stories"
			image="https://lh3.googleusercontent.com/aida-public/AB6AXuCCA42wbVMQDurmOIWHeRc5D2NJEZwmNxFu2w_FZy2G7aQHh2oo3I7RHk6IQ-PTcb20pmtgF2p0S0yYf6QDJzNpbPmx5nLgG5B7hF8E28PNDZBboLUF_vsbSOC0VeCE_piHn1DHMa9zbBrvqT8LqGbbjGpc6V0fIE6HytmR_lxquuDC8AiJz_MbBsXCYyN-JdiV8Z3QAlGPOPP3yN06wT7Xv1RErYL4ZaaFGYVi6hXyQ6YzS5kQNxH1alEXaBNIYWU1syWPmKl6vSs"
		/>

		<!-- Editorial Intro -->
		<section
			class="py-24 px-6 md:px-24 bg-[#f9f9f7] flex flex-col md:flex-row items-baseline gap-12"
		>
			<div class="md:w-1/3">
				<h3 class="serif-display text-4xl leading-tight text-[#2d3432]">
					The Art of Conscious Weaving
				</h3>
			</div>
			<div class="md:w-2/3 border-l border-[#adb3b0]/20 pl-8">
				<p
					class="text-[#5a605e] font-body text-lg leading-relaxed max-w-2xl"
				>
					Our 2024 collection explores the intersection of heritage
					textiles and contemporary silhouettes. Each piece is a
					testament to the slow-fashion movement, crafted by local
					artisans using techniques passed down through generations.
				</p>
			</div>
		</section>

		<!-- Featured Collection Grid -->
		<section class="pb-32 px-6 md:px-12 bg-[#f9f9f7]">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-24">
				{
					products.length > 0 ? (
						products.map((product: any, index: number) => (
							<ProductCard
								name={product.data.name}
								collection={product.data.collection}
								price={`IDR ${product.data.price.toLocaleString("id-ID")}`}
								image={product.data.mainImage}
								slug={product.id}
								mt={index % 2 === 1 ? "md:mt-32" : ""}
							/>
						))
					) : (
						<div class="col-span-2 py-20 text-center">
							<p class="text-[#5a605e]">
								Belum ada produk. Silakan tambah lewat{" "}
								<a href="/keystatic" class="underline">
									Admin CMS
								</a>
								.
							</p>
						</div>
					)
				}
			</div>
		</section>

		<!-- Lifestyle Quote Section -->
		<section
			class="py-32 bg-[#f2f4f2] text-center flex flex-col items-center"
		>
			<span class="material-symbols-outlined text-[#7b5556] mb-6"
				>auto_awesome</span
			>
			<blockquote
				class="serif-display text-3xl md:text-5xl max-w-3xl italic leading-tight px-6 text-[#2d3432]"
			>
				"We don't just make clothes; we curate a relationship between
				the wearer and the heritage of the thread."
			</blockquote>
			<p
				class="text-[10px] uppercase tracking-widest mt-8 text-[#767c79]"
			>
				Founders' Note
			</p>
		</section>
	</main>

	<!-- Footer -->
	<footer
		class="w-full bg-[#f2f4f2] flex flex-col gap-8 p-12 text-center pb-32 md:pb-12"
	>
		<div class="font-['Newsreader'] italic text-lg text-[#5f5e60]">
			BOUTIQUE Editorial Collective
		</div>
		<div class="flex flex-wrap justify-center gap-8">
			<a
				class="text-xs leading-relaxed text-[#5f5e60] hover:text-[#7b5556] transition-colors"
				href="#">Size Guide</a
			>
			<a
				class="text-xs leading-relaxed text-[#5f5e60] hover:text-[#7b5556] transition-colors"
				href="#">Care Instructions</a
			>
			<a
				class="text-xs leading-relaxed text-[#5f5e60] hover:text-[#7b5556] transition-colors"
				href="#">Brand Story</a
			>
		</div>
		<p class="text-xs leading-relaxed text-[#5f5e60] opacity-60">
			© 2024 Editorial Collective
		</p>
	</footer>
</Layout>
